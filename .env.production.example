FRONTEND_PORT=8080

DB_USER=fantaroncola
DB_PASSWORD=change-me-postgres-password
DB_NAME=fantaroncola

JWT_SECRET=change-me-long-random-jwt-secret
SESSION_SECRET=change-me-long-random-session-secret

# Public origin(s) allowed to call the backend. Comma-separate if needed.
CORS_ORIGIN=https://fantaroncola.it,https://www.fantaroncola.it

# Cookie settings for reverse-proxied HTTPS deployments.
SESSION_COOKIE_SAME_SITE=lax
SESSION_COOKIE_SECURE=auto
TRUST_PROXY=1

# Optional admin bootstrap user created/updated at startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password

# Optional auth throttling overrides.
AUTH_RATE_LIMIT_WINDOW_MS=900000
AUTH_RATE_LIMIT_MAX=20
